# OCCP Environment Variables
# Copy to .env and fill in your values. NEVER commit .env to git.

# Core
OCCP_PORT=3000
DATABASE_URL=sqlite:///occp.db

# LLM Providers (enable in config/occp.config.yaml)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Channel Tokens (enable channels in config/occp.config.yaml)
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
TELEGRAM_BOT_TOKEN=

# Dashboard
OCCP_DASH_JWT_SECRET=
