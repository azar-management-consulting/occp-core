# OCCP Environment Variables
# Copy to .env and fill in your values. NEVER commit .env to git.

# ── Core ──────────────────────────────────────────────────────────
OCCP_OCCP_ENV=development
OCCP_DEBUG=false
OCCP_API_HOST=0.0.0.0
OCCP_API_PORT=8000

# ── Database ──────────────────────────────────────────────────────
OCCP_DATABASE_URL=sqlite+aiosqlite:///data/occp.db

# Optional Postgres override (default: SQLite local)
# Uncomment + fill to switch the backend with zero code changes.
# OCCP_DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/occp
# If using Supabase pooler (port 6543), cache is auto-disabled
# OCCP_DATABASE_URL=postgresql+asyncpg://postgres.<proj>:<pass>@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
# OCCP_DATABASE_SSL_MODE=require  # forwarded to asyncpg when set

# ── LLM Providers (install with: pip install occp[llm]) ──────────
OCCP_ANTHROPIC_API_KEY=
OCCP_ANTHROPIC_MODEL=claude-sonnet-4-6
OCCP_OPENAI_API_KEY=

# ── JWT Auth ──────────────────────────────────────────────────────
OCCP_JWT_SECRET=          # auto-generated if empty
OCCP_JWT_EXPIRE_MINUTES=1440

# ── Admin bootstrap ──────────────────────────────────────────────
OCCP_ADMIN_USER=admin
OCCP_ADMIN_PASSWORD=changeme

# ── CORS (JSON array in .env, comma-separated in env vars) ──────
OCCP_CORS_ORIGINS=["http://localhost:3000","https://dash.occp.ai"]

# ── Sandbox executor ───────────────────────────────────────────────
# Backends: nsjail | bwrap | process | mock | (empty = auto-detect)
OCCP_SANDBOX_BACKEND=
OCCP_SANDBOX_TIME_LIMIT=30    # seconds
OCCP_SANDBOX_MEMORY_LIMIT=256 # MB
OCCP_SANDBOX_ENABLE_NETWORK=false
OCCP_SANDBOX_NSJAIL_BIN=nsjail
OCCP_SANDBOX_BWRAP_BIN=bwrap

# ── Rate limiting ────────────────────────────────────────────────
OCCP_RATE_LIMIT_REQUESTS=20   # per window
OCCP_RATE_LIMIT_WINDOW=60     # seconds
OCCP_RATE_LIMIT_PATHS=/api/v1/auth/

# ── Audit retention (EU AI Act Art. 19) ─────────────────────────
OCCP_AUDIT_RETENTION_DAYS=180  # days; 0 = keep forever (min recommended: 180)

# ── Logging ──────────────────────────────────────────────────────
OCCP_LOG_LEVEL=INFO
OCCP_LOG_FORMAT=json          # json | console

# ── Brain / OpenClaw Integration ─────────────────────────────────
OCCP_WEBHOOK_SECRET=             # HMAC-SHA256 shared secret for agent webhooks
OCCP_OPENCLAW_BASE_URL=https://claw.occp.ai  # OpenClaw gateway URL
OCCP_CONFIRMATION_GATE_TIMEOUT=300  # seconds before auto-reject pending confirmations

# ── Brain Orchestration ─────────────────────────────────────────
OCCP_MAX_CONCURRENT_AGENTS=12        # Max parallel agents in a workflow wave
OCCP_MAX_CONCURRENT_PIPELINES=10     # Max parallel pipeline executions
OCCP_BRAIN_SESSION_TIMEOUT=3600      # Brain session idle timeout (seconds)

# ── Channels ─────────────────────────────────────────────────────
OCCP_SLACK_BOT_TOKEN=
OCCP_SLACK_SIGNING_SECRET=
OCCP_TELEGRAM_BOT_TOKEN=
