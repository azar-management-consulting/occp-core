# OCCP Environment Variables
# Copy to .env and fill in your values. NEVER commit .env to git.

# ── Core ──────────────────────────────────────────────────────────
OCCP_OCCP_ENV=development
OCCP_DEBUG=false
OCCP_API_HOST=0.0.0.0
OCCP_API_PORT=8000

# ── Database ──────────────────────────────────────────────────────
OCCP_DATABASE_URL=sqlite+aiosqlite:///data/occp.db

# ── LLM Providers (install with: pip install occp[llm]) ──────────
OCCP_ANTHROPIC_API_KEY=
OCCP_ANTHROPIC_MODEL=claude-sonnet-4-20250514
OCCP_OPENAI_API_KEY=

# ── JWT Auth ──────────────────────────────────────────────────────
OCCP_JWT_SECRET=          # auto-generated if empty
OCCP_JWT_EXPIRE_MINUTES=1440

# ── Admin bootstrap ──────────────────────────────────────────────
OCCP_ADMIN_USER=admin
OCCP_ADMIN_PASSWORD=changeme

# ── CORS (comma-separated) ───────────────────────────────────────
OCCP_CORS_ORIGINS=http://localhost:3000,https://dash.occp.ai

# ── Channels ─────────────────────────────────────────────────────
OCCP_SLACK_BOT_TOKEN=
OCCP_SLACK_SIGNING_SECRET=
OCCP_TELEGRAM_BOT_TOKEN=
