[
  {
    "id": "filesystem",
    "name": "Filesystem",
    "description": "Read and write local files.",
    "package": "@modelcontextprotocol/server-filesystem",
    "category": "core",
    "config_template": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "/path/to/allowed/dir"]
    }
  },
