# OCCP Grafana stack — environment variables
# Copy to .env.grafana and fill in real values. NEVER commit .env.grafana.
# Used by: docker-compose.grafana.yml

# ── Grafana admin ──────────────────────────────────────────────────────────
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=changeme-strong-password-here

# ── Grafana server ─────────────────────────────────────────────────────────
GF_SERVER_ROOT_URL=http://localhost:3000
# GF_SERVER_DOMAIN=grafana.your-domain.com
# GF_SERVER_PROTOCOL=https

# ── SMTP (optional — for email alerts) ────────────────────────────────────
# GF_SMTP_ENABLED=true
# GF_SMTP_HOST=smtp.gmail.com:587
# GF_SMTP_USER=your-smtp-user@gmail.com
# GF_SMTP_PASSWORD=your-app-password
# GF_SMTP_FROM_ADDRESS=grafana@your-domain.com
# GF_SMTP_FROM_NAME=OCCP Grafana

# ── PagerDuty (for burn-rate alert channel) ────────────────────────────────
# Paste the PagerDuty Events API v2 integration key here.
# Configure the contact point in Grafana UI: Alerting > Contact points > occp-pagerduty
PAGERDUTY_INTEGRATION_KEY=your-pagerduty-integration-key-here

# ── Alertmanager ───────────────────────────────────────────────────────────
ALERTMANAGER_EXTERNAL_URL=http://localhost:9093

# ── Grafana feature flags (optional) ──────────────────────────────────────
# GF_FEATURE_TOGGLES_ENABLE=publicDashboards
