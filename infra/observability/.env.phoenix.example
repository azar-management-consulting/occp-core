# ----------------------------------------------------------------------------
# Phoenix stack configuration — copy to .env.phoenix and edit secrets.
# NEVER commit the real .env.phoenix file.
# ----------------------------------------------------------------------------

# Bind address (0.0.0.0 inside the container; the reverse proxy terminates TLS).
PHOENIX_HOST=0.0.0.0

# Phoenix UI port (mapped to host).
PHOENIX_PORT=6006

# OTLP gRPC ingestion port.
PHOENIX_GRPC_PORT=4317

# OTLP HTTP ingestion port (served off the UI container; proxied to 6006 internally).
PHOENIX_HTTP_PORT=4318

# --- Postgres credentials ---------------------------------------------------
# Used by the postgres service itself AND referenced by PHOENIX_DB_URL below.
PHOENIX_PG_USER=phoenix
PHOENIX_PG_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
PHOENIX_PG_DB=phoenix

# --- Phoenix app ------------------------------------------------------------
# Connection string Phoenix uses to persist traces/datasets.
# Host = service name on the occp-obs docker network.
PHOENIX_DB_URL=postgresql://phoenix:REPLACE_WITH_STRONG_PASSWORD@phoenix-postgres:5432/phoenix

# Enable built-in auth (recommended for any public exposure).
PHOENIX_ENABLE_AUTH=true

# Session / JWT secret — generate with: openssl rand -hex 32
PHOENIX_SECRET=REPLACE_WITH_openssl_rand_hex_32
