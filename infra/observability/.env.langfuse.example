# ----------------------------------------------------------------------------
# Langfuse v3 stack configuration — copy to .env.langfuse and edit secrets.
# NEVER commit the real .env.langfuse file.
# ----------------------------------------------------------------------------

# --- Public URL (reverse proxy target) --------------------------------------
# Must match the hostname Cloudflare/Caddy terminates for.
NEXTAUTH_URL=https://traces.occp.ai

# --- Web ports --------------------------------------------------------------
LANGFUSE_WEB_PORT=3100

# --- Postgres (app state) ---------------------------------------------------
LANGFUSE_PG_USER=langfuse
LANGFUSE_PG_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
LANGFUSE_PG_DB=langfuse
LANGFUSE_DATABASE_URL=postgresql://langfuse:REPLACE_WITH_STRONG_PASSWORD@langfuse-postgres:5432/langfuse

# --- ClickHouse (trace store) -----------------------------------------------
CLICKHOUSE_DB=default
CLICKHOUSE_USER=clickhouse
CLICKHOUSE_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
LANGFUSE_CLICKHOUSE_URL=http://langfuse-clickhouse:8123
LANGFUSE_CLICKHOUSE_MIGRATION_URL=clickhouse://langfuse-clickhouse:9000

# --- Redis (queue + cache) --------------------------------------------------
REDIS_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
LANGFUSE_REDIS_URL=redis://default:REPLACE_WITH_STRONG_PASSWORD@langfuse-redis:6379

# --- NextAuth / crypto ------------------------------------------------------
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=REPLACE_WITH_openssl_rand_base64_32

# Generate with: openssl rand -base64 32
SALT=REPLACE_WITH_openssl_rand_base64_32

# Generate with: openssl rand -hex 32   (MUST be 32 bytes / 64 hex chars)
ENCRYPTION_KEY=REPLACE_WITH_openssl_rand_hex_32

# --- Optional bootstrap -----------------------------------------------------
# Pre-seed the first admin on cold start. Leave empty to use the signup UI.
LANGFUSE_INIT_ORG_ID=
LANGFUSE_INIT_ORG_NAME=OCCP
LANGFUSE_INIT_PROJECT_ID=
LANGFUSE_INIT_PROJECT_NAME=occp-api
LANGFUSE_INIT_USER_EMAIL=
LANGFUSE_INIT_USER_PASSWORD=
