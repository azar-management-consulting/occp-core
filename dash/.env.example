# OCCP Dashboard – environment example
# Copy to .env.local for development; configure per-env on Vercel/hosting.

# Feature flag: gate the v2 dashboard shell.
# When "true":
#   - /pipeline, /agents, /audit, /mcp, /settings, /admin -> 302 to /v2/<path>
#   - /v2/* is reachable
# When unset or "false":
#   - legacy routes serve as before
#   - /v2/* is hidden (rewritten to /404)
NEXT_PUBLIC_DASH_V2=false   # flip to true to route /pipeline -> /v2/pipeline etc.
