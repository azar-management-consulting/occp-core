FROM python:3.13-slim AS base

WORKDIR /app

# Install system dependencies for sandboxing
RUN apt-get update && \
    apt-get install -y --no-install-recommends bubblewrap curl git openssh-client && \
    rm -rf /var/lib/apt/lists/*

# Install uv for faster dependency resolution
RUN curl -LsSf https://astral.sh/uv/install.sh | sh

COPY pyproject.toml .
COPY orchestrator/ orchestrator/
COPY policy_engine/ policy_engine/
COPY adapters/ adapters/
COPY api/ api/
COPY config/ config/
COPY store/ store/
COPY cli/ cli/
COPY sdk/ sdk/
COPY security/ security/
# L6 foundation (v0.10.0)
COPY observability/ observability/
COPY evaluation/ evaluation/
COPY architecture/ architecture/
# Auto-dev pipeline (v0.10.0)
COPY autodev/ autodev/

# Pre-compile .pyc → -30% cold start (2026 best practice)
ENV UV_COMPILE_BYTECODE=1 \
    UV_LINK_MODE=copy \
    PYTHONDONTWRITEBYTECODE=0 \
    PYTHONUNBUFFERED=1

RUN /root/.local/bin/uv pip install --system --no-cache -e '.[llm]'

RUN groupadd --system --gid 1001 occp && \
    useradd --system --uid 1001 --gid occp occp && \
    mkdir -p /app/data && chown -R occp:occp /app/data

USER occp
EXPOSE 8000

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
  CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:8000/api/v1/status')"

CMD ["uvicorn", "api.app:app", "--host", "0.0.0.0", "--port", "8000"]
